# Real secrets belong in .env, not in tracked json files.
ConnectionStrings__SqlServer=Server=localhost;Database=TravelPlannerApp;Integrated Security=true;TrustServerCertificate=true
# Optional only if you run the SQL Server container from docker-compose.yml
MSSQL_SA_PASSWORD=replace-with-a-strong-sql-server-password
Jwt__Issuer=TravelPlannerApp.Api
Jwt__Audience=TravelPlannerApp.Frontend
Jwt__Secret=replace-with-a-long-random-jwt-secret-at-least-32-characters
Jwt__TokenLifetimeMinutes=120
Seed__DefaultUserPassword=replace-with-a-dev-seed-password
